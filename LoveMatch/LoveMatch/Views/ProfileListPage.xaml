<ContentPage
    x:Class="LoveMatch.Views.ProfileListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <CollectionView x:Name="ProfilesCollection">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Stroke="Gray" StrokeThickness="1" Padding="10" Margin="5">
                    <VerticalStackLayout>

                        <Label Text="{Binding Name}" FontAttributes="Bold"/>
                        <Label Text="{Binding Age, StringFormat='Leeftijd: {0}'}"/>
                        <Label Text="{Binding Bio}" FontAttributes="Italic"/>

                        <!-- Knop voor Liken/Selecteren -->
                        <Button Text="Selecteer" Clicked="OnSelectClicked"/>

                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>